# Copy this file to `.env` (repo root) and fill in your keys.
# Read by the FastAPI backend via python-dotenv.

# TMDB — free API key: https://developer.themoviedb.org
TMDB_API_KEY=your_tmdb_key_here

# Groq — free API key: https://console.groq.com  (model: llama-3.3-70b-versatile)
GROQ_API_KEY=your_groq_key_here

# OMDb — OPTIONAL. Powers IMDb / Rotten Tomatoes / Metacritic scores on cards + the modal.
# Free key (1000 req/day): https://www.omdbapi.com/apikey.aspx  (activate via the email link!)
# If unset, the app simply hides those badges (TMDB score still shows).
OMDB_API_KEY=your_omdb_key_here

# ── Deployment config (OPTIONAL — sensible defaults for local dev) ──
# Database connection string. Default: local SQLite file.
# DATABASE_URL=sqlite:///./movie_night.db
# Comma-separated CORS origins the API accepts. Default: http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000,https://yourapp.example.com
